{
  "name": "companies-api-lambda",
  "version": "1.0.0",
  "description": "AWS Lambda functions for Companies API",
  "main": "handler.js",
  "scripts": {
    "build": "tsc",
    "start:local": "serverless offline start",
    "deploy:dev": "serverless deploy --stage dev",
    "deploy:prod": "serverless deploy --stage prod",
    "remove": "serverless remove",
    "logs:dev": "serverless logs -f createCompany --stage dev --tail",
    "invoke:local": "serverless invoke local -f createCompany"
  },
  "dependencies": {
    "aws-lambda": "^1.0.7",
    "mongodb": "^6.3.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.136",
    "@types/node": "^20.19.39",
    "serverless": "^4.5.15",
    "serverless-offline": "^14.5.0",
    "typescript": "^5.0.0"
  }
}
